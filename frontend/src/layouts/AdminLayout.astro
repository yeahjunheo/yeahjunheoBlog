---
import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | Admin</title>
  </head>
  <body class="min-h-screen flex flex-col bg-gray-50 text-gray-900">
    <nav class="bg-gray-900 text-white">
      <div class="max-w-5xl mx-auto px-4 py-3 flex items-center justify-between">
        <div class="flex items-center gap-6">
          <span class="font-bold text-lg">Admin</span>
          <a href="/admin" class="hover:text-gray-300">Posts</a>
          <a href="/admin/tags" class="hover:text-gray-300">Tags</a>
        </div>
        <div class="flex items-center gap-4">
          <a href="/" class="hover:text-gray-300 text-sm">View Site</a>
          <button id="logout-btn" class="text-sm bg-gray-700 hover:bg-gray-600 px-3 py-1 rounded">
            Logout
          </button>
        </div>
      </div>
    </nav>
    <main class="flex-1 max-w-5xl mx-auto w-full px-4 py-8">
      <slot />
    </main>
    <script>
      import { logout } from "../lib/api";
      document.getElementById("logout-btn")?.addEventListener("click", async () => {
        await logout();
        window.location.href = "/admin/login";
      });
    </script>
  </body>
</html>
