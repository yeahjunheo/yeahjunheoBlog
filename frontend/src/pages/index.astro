---
import HomeLayout from "../layouts/HomeLayout.astro";
import PostCard from "../components/PostCard.astro";
import { getPublishedPosts } from "../lib/api";

const posts = await getPublishedPosts(1, 0);
const latestPost = posts[0];
---

<HomeLayout title="yeahjunheo">
  <section>
    <h2 class="text-xs font-semibold uppercase tracking-widest text-text-secondary mb-4">Latest Post</h2>
    <div class="border-t border-border-medium"></div>
    {latestPost ? (
      <PostCard post={latestPost} featured />
    ) : (
      <p class="text-text-secondary text-lg py-8">No posts yet.</p>
    )}
  </section>
</HomeLayout>
