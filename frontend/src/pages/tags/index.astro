---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllTagsWithCounts } from "../../lib/api";

const tags = await getAllTagsWithCounts();
---

<BaseLayout title="Tags">
  <h1 class="text-4xl font-bold mb-6">Tags</h1>
  {tags.length === 0 ? (
    <p class="text-text-secondary">No tags yet.</p>
  ) : (
    <div id="bubble-wrap" class="relative w-full" style="height: 500px;">
      <canvas id="bubble-canvas" class="w-full h-full"></canvas>
    </div>
  )}

  <script is:inline define:vars={{ tags }}>
    window.__TAGS_DATA = tags;
  </script>

  <script>
    const tagsData = (window as any).__TAGS_DATA as Array<{
      id: string;
      name: string;
      slug: string;
      post_count: number;
    }>;

    if (tagsData.length > 0) {
      const canvas = document.getElementById("bubble-canvas") as HTMLCanvasElement;
      const wrap = document.getElementById("bubble-wrap") as HTMLElement;
      const ctx = canvas.getContext("2d")!;

      const ACCENT = "#2d5a3d";
      const MIN_RADIUS = 30;
      const MAX_RADIUS = 70;
      const MOUSE_REPEL_RADIUS = 30;
      const MOUSE_REPEL_FORCE = 8;
      const SPRING_STIFFNESS = 0.03;
      const DAMPING = 0.85;
      const DRAG_THRESHOLD = 5;

      interface Bubble {
        x: number;
        y: number;
        homeX: number;
        homeY: number;
        vx: number;
        vy: number;
        radius: number;
        tag: (typeof tagsData)[0];
        opacity: number;
      }

      let bubbles: Bubble[] = [];
      let mouseX = -9999;
      let mouseY = -9999;
      let dragBubble: Bubble | null = null;
      let dragStartX = 0;
      let dragStartY = 0;
      let didDrag = false;
      let dpr = window.devicePixelRatio || 1;

      function resize() {
        const rect = wrap.getBoundingClientRect();
        dpr = window.devicePixelRatio || 1;
        canvas.width = rect.width * dpr;
        canvas.height = rect.height * dpr;
        canvas.style.width = rect.width + "px";
        canvas.style.height = rect.height + "px";
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        return { w: rect.width, h: rect.height };
      }

      function initBubbles() {
        const { w, h } = resize();
        const maxCount = Math.max(...tagsData.map((t) => t.post_count), 1);

        bubbles = tagsData.map((tag) => {
          const t = maxCount > 0 ? tag.post_count / maxCount : 0;
          const radius = MIN_RADIUS + t * (MAX_RADIUS - MIN_RADIUS);
          return {
            x: 0,
            y: 0,
            homeX: 0,
            homeY: 0,
            vx: 0,
            vy: 0,
            radius,
            tag,
            opacity: 0.5 + t * 0.4,
          };
        });

        // Sort largest first for packing
        bubbles.sort((a, b) => b.radius - a.radius);

        // Circle-pack from center
        const cx = w / 2;
        const cy = h / 2;

        for (let i = 0; i < bubbles.length; i++) {
          const b = bubbles[i];
          if (i === 0) {
            b.homeX = cx;
            b.homeY = cy;
          } else {
            // Place by spiraling outward
            let placed = false;
            for (let angle = 0; angle < Math.PI * 20; angle += 0.15) {
              const dist = 10 + angle * 8;
              const tx = cx + Math.cos(angle) * dist;
              const ty = cy + Math.sin(angle) * dist;
              let overlaps = false;
              for (let j = 0; j < i; j++) {
                const dx = tx - bubbles[j].homeX;
                const dy = ty - bubbles[j].homeY;
                const minDist = b.radius + bubbles[j].radius + 4;
                if (dx * dx + dy * dy < minDist * minDist) {
                  overlaps = true;
                  break;
                }
              }
              if (!overlaps) {
                b.homeX = tx;
                b.homeY = ty;
                placed = true;
                break;
              }
            }
            if (!placed) {
              b.homeX = cx + (Math.random() - 0.5) * w * 0.6;
              b.homeY = cy + (Math.random() - 0.5) * h * 0.6;
            }
          }
          b.x = b.homeX;
          b.y = b.homeY;
        }
      }

      function hexToRgb(hex: string) {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        return { r, g, b };
      }

      function draw() {
        const w = canvas.width / dpr;
        const h = canvas.height / dpr;
        ctx.clearRect(0, 0, w, h);

        const rgb = hexToRgb(ACCENT);

        for (const b of bubbles) {
          // Draw circle
          ctx.beginPath();
          ctx.arc(b.x, b.y, b.radius, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${rgb.r}, ${rgb.g}, ${rgb.b}, ${b.opacity})`;
          ctx.fill();

          // Draw border
          ctx.strokeStyle = ACCENT;
          ctx.lineWidth = 1.5;
          ctx.stroke();

          // Draw text
          const fontSize = Math.max(10, Math.min(b.radius * 0.35, 16));
          ctx.font = `500 ${fontSize}px Inter, sans-serif`;
          ctx.textAlign = "center";
          ctx.textBaseline = "middle";
          ctx.fillStyle = b.opacity > 0.65 ? "#ffffff" : "#1a1a1a";
          ctx.fillText(b.tag.name, b.x, b.y - fontSize * 0.3);

          // Draw count
          const countSize = Math.max(9, fontSize * 0.75);
          ctx.font = `400 ${countSize}px Inter, sans-serif`;
          ctx.fillStyle = b.opacity > 0.65 ? "rgba(255,255,255,0.8)" : "rgba(26,26,26,0.6)";
          ctx.fillText(
            b.tag.post_count === 1 ? "1 post" : `${b.tag.post_count} posts`,
            b.x,
            b.y + fontSize * 0.55
          );
        }
      }

      function update() {
        for (const b of bubbles) {
          if (b === dragBubble) continue;

          // Spring toward home
          const dx = b.homeX - b.x;
          const dy = b.homeY - b.y;
          b.vx += dx * SPRING_STIFFNESS;
          b.vy += dy * SPRING_STIFFNESS;

          // Mouse repulsion
          const mx = b.x - mouseX;
          const my = b.y - mouseY;
          const mDist = Math.sqrt(mx * mx + my * my);
          if (mDist < MOUSE_REPEL_RADIUS + b.radius && mDist > 0) {
            const force = MOUSE_REPEL_FORCE * (1 - mDist / (MOUSE_REPEL_RADIUS + b.radius));
            b.vx += (mx / mDist) * force;
            b.vy += (my / mDist) * force;
          }

          // Bubble-bubble collision
          for (const other of bubbles) {
            if (other === b) continue;
            const bx = b.x - other.x;
            const by = b.y - other.y;
            const dist = Math.sqrt(bx * bx + by * by);
            const minDist = b.radius + other.radius + 2;
            if (dist < minDist && dist > 0) {
              const overlap = minDist - dist;
              const nx = bx / dist;
              const ny = by / dist;
              b.vx += nx * overlap * 0.15;
              b.vy += ny * overlap * 0.15;
            }
          }

          b.vx *= DAMPING;
          b.vy *= DAMPING;
          b.x += b.vx;
          b.y += b.vy;
        }
      }

      function loop() {
        update();
        draw();
        requestAnimationFrame(loop);
      }

      // --- Event handlers ---

      function getMousePos(e: MouseEvent) {
        const rect = canvas.getBoundingClientRect();
        return { x: e.clientX - rect.left, y: e.clientY - rect.top };
      }

      function findBubble(x: number, y: number): Bubble | null {
        // Check in reverse (top-drawn last) for correct hit testing
        for (let i = bubbles.length - 1; i >= 0; i--) {
          const b = bubbles[i];
          const dx = x - b.x;
          const dy = y - b.y;
          if (dx * dx + dy * dy <= b.radius * b.radius) return b;
        }
        return null;
      }

      canvas.addEventListener("mousemove", (e) => {
        const pos = getMousePos(e);
        mouseX = pos.x;
        mouseY = pos.y;

        if (dragBubble) {
          dragBubble.x = pos.x;
          dragBubble.y = pos.y;
          dragBubble.vx = 0;
          dragBubble.vy = 0;
          const totalDx = pos.x - dragStartX;
          const totalDy = pos.y - dragStartY;
          if (Math.sqrt(totalDx * totalDx + totalDy * totalDy) > DRAG_THRESHOLD) {
            didDrag = true;
          }
        }

        // Cursor style
        const hit = findBubble(pos.x, pos.y);
        canvas.style.cursor = hit ? "pointer" : "default";
      });

      canvas.addEventListener("mouseleave", () => {
        mouseX = -9999;
        mouseY = -9999;
        if (dragBubble) {
          dragBubble = null;
          didDrag = false;
        }
      });

      canvas.addEventListener("mousedown", (e) => {
        const pos = getMousePos(e);
        const hit = findBubble(pos.x, pos.y);
        if (hit) {
          dragBubble = hit;
          dragStartX = pos.x;
          dragStartY = pos.y;
          didDrag = false;
        }
      });

      canvas.addEventListener("mouseup", () => {
        if (dragBubble && !didDrag) {
          // Click — navigate
          window.location.href = `/tags/${dragBubble.tag.slug}`;
        }
        dragBubble = null;
        didDrag = false;
      });

      // --- Touch support ---

      canvas.addEventListener("touchstart", (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        const pos = getMousePos(touch as unknown as MouseEvent);
        mouseX = pos.x;
        mouseY = pos.y;
        const hit = findBubble(pos.x, pos.y);
        if (hit) {
          dragBubble = hit;
          dragStartX = pos.x;
          dragStartY = pos.y;
          didDrag = false;
        }
      }, { passive: false });

      canvas.addEventListener("touchmove", (e) => {
        e.preventDefault();
        const touch = e.touches[0];
        const pos = getMousePos(touch as unknown as MouseEvent);
        mouseX = pos.x;
        mouseY = pos.y;
        if (dragBubble) {
          dragBubble.x = pos.x;
          dragBubble.y = pos.y;
          dragBubble.vx = 0;
          dragBubble.vy = 0;
          const totalDx = pos.x - dragStartX;
          const totalDy = pos.y - dragStartY;
          if (Math.sqrt(totalDx * totalDx + totalDy * totalDy) > DRAG_THRESHOLD) {
            didDrag = true;
          }
        }
      }, { passive: false });

      canvas.addEventListener("touchend", () => {
        mouseX = -9999;
        mouseY = -9999;
        if (dragBubble && !didDrag) {
          window.location.href = `/tags/${dragBubble.tag.slug}`;
        }
        dragBubble = null;
        didDrag = false;
      });

      // --- Init ---

      initBubbles();
      loop();

      window.addEventListener("resize", () => {
        initBubbles();
      });
    }
  </script>
</BaseLayout>
