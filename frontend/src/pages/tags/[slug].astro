---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import Pagination from "../../components/Pagination.astro";
import { getPostsByTag } from "../../lib/api";

const { slug } = Astro.params;
const POSTS_PER_PAGE = 10;
const page = Math.max(1, Number(Astro.url.searchParams.get("page")) || 1);
const offset = (page - 1) * POSTS_PER_PAGE;

const posts = await getPostsByTag(slug!, POSTS_PER_PAGE + 1, offset);
const hasMore = posts.length > POSTS_PER_PAGE;
const displayPosts = posts.slice(0, POSTS_PER_PAGE);
---

<BaseLayout title={`Posts tagged "${slug}"`}>
  <h1 class="text-3xl font-bold mb-2">Tag: {slug}</h1>
  <a href="/tags" class="text-sm text-gray-500 hover:text-gray-700 mb-6 inline-block">&larr; All tags</a>
  {displayPosts.length === 0 ? (
    <p class="text-gray-500 mt-4">No posts with this tag.</p>
  ) : (
    <div>
      {displayPosts.map((post) => (
        <PostCard post={post} />
      ))}
    </div>
  )}
  <Pagination currentPage={page} hasMore={hasMore} baseUrl={`/tags/${slug}`} />
</BaseLayout>
