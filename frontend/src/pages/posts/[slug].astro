---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getPostBySlug } from "../../lib/api";
import { renderMarkdown } from "../../lib/markdown";
import { formatDate, readingTime } from "../../lib/utils";

const { slug } = Astro.params;
const post = await getPostBySlug(slug!);

if (!post) {
  return Astro.redirect("/404");
}

const html = renderMarkdown(post.content);
const time = readingTime(post.content);
---

<BaseLayout title={post.title} description={post.excerpt || undefined}>
  <article>
    <header class="mb-10">
      <h1 class="text-4xl md:text-5xl font-bold leading-tight">{post.title}</h1>
      <div class="flex items-center gap-3 mt-4 text-sm text-text-secondary">
        <time>{formatDate(post.published_at || post.created_at)}</time>
        <span>&middot;</span>
        <span>{time}</span>
      </div>
    </header>
    <div class="prose prose-neutral max-w-none font-serif" set:html={html} />
  </article>
  <div class="mt-10 pt-4 border-t border-border-light">
    <a href="/posts" class="text-accent hover:text-accent-light transition-colors inline-block py-2">&larr; Back to posts</a>
  </div>
</BaseLayout>
