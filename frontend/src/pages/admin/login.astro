---
import "../../styles/global.css";
const apiUrl = process.env.API_URL || "http://localhost:8080";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login | Admin</title>
    <script define:vars={{ apiUrl }}>window.__API_URL = apiUrl;</script>
  </head>
  <body class="min-h-screen flex items-center justify-center bg-gray-50">
    <div class="bg-white p-8 rounded-lg shadow-md w-full max-w-sm">
      <h1 class="text-2xl font-bold mb-6 text-center">Admin Login</h1>
      <form id="login-form" class="space-y-4">
        <div>
          <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
          <input
            type="text"
            id="username"
            name="username"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"
          />
        </div>
        <div>
          <label for="password" class="block text-sm font-medium text-gray-700 mb-1">Password</label>
          <input
            type="password"
            id="password"
            name="password"
            required
            class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-gray-900"
          />
        </div>
        <div id="error" class="text-red-600 text-sm hidden">Invalid credentials.</div>
        <button
          type="submit"
          class="w-full bg-gray-900 text-white py-2 rounded hover:bg-gray-800"
        >
          Login
        </button>
      </form>
    </div>

    <script>
      import { login } from "../../lib/api";

      const form = document.getElementById("login-form") as HTMLFormElement;
      const errorEl = document.getElementById("error")!;

      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        errorEl.classList.add("hidden");

        const username = (document.getElementById("username") as HTMLInputElement).value;
        const password = (document.getElementById("password") as HTMLInputElement).value;

        const ok = await login(username, password);
        if (ok) {
          window.location.href = "/admin";
        } else {
          errorEl.classList.remove("hidden");
        }
      });
    </script>
  </body>
</html>
