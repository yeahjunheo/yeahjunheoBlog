---
import { getAllTags } from "../lib/api";

const now = new Date();
const dateStr = now.toLocaleDateString("en-US", {
  month: "long",
  day: "numeric",
  year: "numeric",
});

const pathname = Astro.url.pathname;
const tags = await getAllTags();
---

<!-- Mobile top bar -->
<div class="md:hidden fixed top-0 left-0 right-0 z-40 bg-white border-b border-border-medium flex items-center px-4 h-14">
  <button id="mobile-menu-toggle" aria-label="Open menu" class="p-2 -ml-2 text-text-secondary hover:text-accent transition-colors">
    <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <line x1="3" y1="6" x2="21" y2="6"></line>
      <line x1="3" y1="12" x2="21" y2="12"></line>
      <line x1="3" y1="18" x2="21" y2="18"></line>
    </svg>
  </button>
  <div class="absolute left-1/2 -translate-x-1/2 text-center">
    <a href="/" class="hover:opacity-80">
      <h1 class="text-2xl font-bold tracking-tight leading-tight">yeahjunheo</h1>
    </a>
  </div>
</div>

<!-- Mobile fullscreen menu -->
<div id="mobile-menu" class="md:hidden fixed inset-0 z-50 bg-white flex-col justify-between px-6 py-8 hidden">
  <div>
    <div class="flex items-center justify-between">
      <a href="/" class="hover:opacity-80">
        <h1 class="text-2xl font-bold tracking-tight leading-tight">yeahjunheo</h1>
      </a>
      <button id="mobile-menu-close" aria-label="Close menu" class="p-2 text-text-secondary hover:text-accent transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
    <p class="text-text-secondary text-sm mt-1">{dateStr}</p>

    <div class="border-t border-border-light mt-6 mb-6"></div>

    <nav class="flex flex-col gap-1">
      <a
        href="/"
        class:list={[
          "text-base uppercase tracking-widest transition-colors py-3",
          pathname === "/" ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
        ]}
      >Home</a>
      <a
        href="/posts"
        class:list={[
          "text-base uppercase tracking-widest transition-colors py-3",
          pathname.startsWith("/posts") ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
        ]}
      >Posts</a>
      <div>
        <div class="flex items-center gap-2 py-3">
          <a
            href="/tags"
            class:list={[
              "text-base uppercase tracking-widest transition-colors",
              pathname.startsWith("/tags") ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
            ]}
          >Tags</a>
          <button data-mobile-tags-toggle class="text-text-secondary hover:text-accent transition-colors">
            <svg class="w-3 h-3 transition-transform duration-200 rotate-180" data-mobile-tags-chevron viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 4 6 8 10 4"></polyline></svg>
          </button>
        </div>
        <div data-mobile-tags-list class="flex flex-col gap-1 pl-4 pb-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag.slug}`}
              class:list={[
                "text-base transition-colors py-2",
                pathname === `/tags/${tag.slug}` ? "text-accent font-medium" : "text-text-secondary hover:text-accent",
              ]}
            >{tag.name}</a>
          ))}
        </div>
      </div>
      <a
        href="/about"
        class:list={[
          "text-base uppercase tracking-widest transition-colors py-3",
          pathname === "/about" ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
        ]}
      >About</a>
    </nav>
  </div>

  <div>
    <div class="border-t border-border-light mb-4"></div>
    <p class="text-text-secondary text-sm leading-relaxed">May the eyes that come across this page turn a little brighter.</p>
  </div>
</div>

<!-- Desktop sidebar -->
<aside class="hidden md:flex w-56 shrink-0 border-r border-border-medium h-screen sticky top-0 flex-col justify-between px-6 py-8">
  <div>
    <a href="/" class="hover:opacity-80">
      <h1 class="text-2xl font-bold tracking-tight leading-tight">yeahjunheo</h1>
    </a>
    <p class="text-text-secondary text-xs mt-1">{dateStr}</p>

    <div class="border-t border-border-light mt-6 mb-6"></div>

    <nav class="flex flex-col gap-4">
      <a
        href="/"
        class:list={[
          "text-xs uppercase tracking-widest transition-colors",
          pathname === "/" ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
        ]}
      >Home</a>
      <a
        href="/posts"
        class:list={[
          "text-xs uppercase tracking-widest transition-colors",
          pathname.startsWith("/posts") ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
        ]}
      >Posts</a>
      <div>
        <div class="flex items-center gap-1.5">
          <a
            href="/tags"
            class:list={[
              "text-xs uppercase tracking-widest transition-colors",
              pathname.startsWith("/tags") ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
            ]}
          >Tags</a>
          <button data-desktop-tags-toggle class="text-text-secondary hover:text-accent transition-colors">
            <svg class="w-2.5 h-2.5 transition-transform duration-200 rotate-180" data-desktop-tags-chevron viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="2 4 6 8 10 4"></polyline></svg>
          </button>
        </div>
        <div data-desktop-tags-list class="flex flex-col gap-2 pl-3 mt-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag.slug}`}
              class:list={[
                "text-xs transition-colors",
                pathname === `/tags/${tag.slug}` ? "text-accent font-medium" : "text-text-secondary hover:text-accent",
              ]}
            >{tag.name}</a>
          ))}
        </div>
      </div>
      <a
        href="/about"
        class:list={[
          "text-xs uppercase tracking-widest transition-colors",
          pathname === "/about" ? "text-accent font-semibold" : "text-text-secondary hover:text-accent",
        ]}
      >About</a>
    </nav>
  </div>

  <div>
    <div class="border-t border-border-light mb-4"></div>
    <p class="text-text-secondary text-xs leading-relaxed">May the eyes that come across this page turn a little brighter.</p>
  </div>
</aside>

<script>
  const openBtn = document.getElementById("mobile-menu-toggle");
  const closeBtn = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");

  function open() {
    menu?.classList.remove("hidden");
    menu?.classList.add("flex");
    document.body.style.overflow = "hidden";
  }

  function close() {
    menu?.classList.add("hidden");
    menu?.classList.remove("flex");
    document.body.style.overflow = "";
  }

  openBtn?.addEventListener("click", open);
  closeBtn?.addEventListener("click", close);

  function setupTagsDropdown(toggleAttr: string, listAttr: string, chevronAttr: string) {
    const toggle = document.querySelector(`[${toggleAttr}]`);
    const list = document.querySelector(`[${listAttr}]`);
    const chevron = document.querySelector(`[${chevronAttr}]`);
    if (!toggle || !list) return;

    toggle.addEventListener("click", () => {
      const isVisible = !list.classList.contains("hidden");
      if (isVisible) {
        list.classList.add("hidden");
        list.classList.remove("flex");
        chevron?.classList.remove("rotate-180");
      } else {
        list.classList.remove("hidden");
        list.classList.add("flex");
        chevron?.classList.add("rotate-180");
      }
    });
  }

  setupTagsDropdown("data-desktop-tags-toggle", "data-desktop-tags-list", "data-desktop-tags-chevron");
  setupTagsDropdown("data-mobile-tags-toggle", "data-mobile-tags-list", "data-mobile-tags-chevron");
</script>
