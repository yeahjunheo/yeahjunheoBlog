---
const now = new Date();
const dateStr = now.toLocaleDateString("en-US", {
  weekday: "long",
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<header class="max-w-4xl mx-auto w-full px-4">
  <div class="border-t border-border-medium mt-4"></div>
  <div class="py-6 text-center">
    <a href="/" class="hover:opacity-80">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight">yeahjunheo</h1>
    </a>
    <p class="text-text-secondary text-sm mt-2">{dateStr}</p>
  </div>
  <div class="border-t border-border-light"></div>
  <nav class="flex justify-center gap-8 py-3">
    <a href="/" class="text-xs uppercase tracking-widest text-text-secondary hover:text-accent transition-colors">Posts</a>
    <a href="/tags" class="text-xs uppercase tracking-widest text-text-secondary hover:text-accent transition-colors">Tags</a>
    <a href="/about" class="text-xs uppercase tracking-widest text-text-secondary hover:text-accent transition-colors">About</a>
  </nav>
  <div class="border-t border-border-medium"></div>
</header>
