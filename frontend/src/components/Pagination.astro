---
interface Props {
  currentPage: number;
  hasMore: boolean;
  baseUrl: string;
}

const { currentPage, hasMore, baseUrl } = Astro.props;
const prevUrl = currentPage > 1 ? `${baseUrl}?page=${currentPage - 1}` : null;
const nextUrl = hasMore ? `${baseUrl}?page=${currentPage + 1}` : null;
---

{(prevUrl || nextUrl) && (
  <div class="flex justify-between items-center mt-10 pt-4 border-t border-border-light">
    {prevUrl ? (
      <a href={prevUrl} class="text-xs uppercase tracking-widest text-text-secondary hover:text-accent transition-colors">&larr; Previous</a>
    ) : (
      <span />
    )}
    {nextUrl ? (
      <a href={nextUrl} class="text-xs uppercase tracking-widest text-text-secondary hover:text-accent transition-colors">Next &rarr;</a>
    ) : (
      <span />
    )}
  </div>
)}
