---
import { Icon } from "astro-icon/components";
---

<footer class="px-6 py-6 text-zissou-bright-black">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-3">
    <p class="font-serif italic text-zissou-foreground">Let the eyes that land on this page leave just a little brighter.</p>
    <p class="text-sm">&copy; 2028 (just after I've done serving) yeahjunheo</p>
    <div class="flex gap-4">
      <a href="https://github.com/yeahjunheo" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="hover:text-zissou-foreground">
        <Icon name="simple-icons:github" size={24} />
      </a>
      <a href="https://www.linkedin.com/in/yeahjunheo/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="hover:text-zissou-foreground">
        <Icon name="simple-icons:linkedin" size={24} />
      </a>
      <a href="https://x.com/yeahjunheo" target="_blank" rel="noopener noreferrer" aria-label="X" class="hover:text-zissou-foreground">
        <Icon name="simple-icons:x" size={24} />
      </a>
    </div>
  </div>
</footer>
