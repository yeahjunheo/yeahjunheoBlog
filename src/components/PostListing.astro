---
import { getCollection, type CollectionEntry } from "astro:content";

interface Props {
  limit?: number;
  posts?: CollectionEntry<"posts">[];
}

const { limit = 10, posts: providedPosts } = Astro.props;

const posts = providedPosts ?? (await getCollection("posts"))
  .filter((p) => p.data.published)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, limit);

const MONTHS = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

const DESKTOP = { titleW: 50, viewsW: 6, gap: "        ", withTime: true };
const MOBILE = { titleW: 36, viewsW: 4, gap: "  ", withTime: false };

function fmtDate(d: Date, withTime: boolean): string {
  const dd = String(d.getDate()).padStart(2, "0");
  const mon = MONTHS[d.getMonth()];
  const yyyy = d.getFullYear();
  if (!withTime) return `${dd}-${mon}-${yyyy}`;
  const hh = String(d.getHours()).padStart(2, "0");
  const mm = String(d.getMinutes()).padStart(2, "0");
  return `${dd}-${mon}-${yyyy} ${hh}:${mm}`;
}

function truncate(s: string, w: number): string {
  return s.length <= w ? s.padEnd(w) : s.slice(0, w - 3) + "..>";
}

function esc(s: string): string {
  return s
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;");
}

function render(opts: { titleW: number; viewsW: number; gap: string; withTime: boolean }): string {
  if (posts.length === 0) return "(no posts yet)\n";
  const placeholder = "-".padStart(opts.viewsW);
  return posts
    .map((post) => {
      const id = esc(post.id);
      const title = esc(truncate(post.data.title, opts.titleW));
      const href = esc(`/posts/${post.id}`);
      const date = fmtDate(post.data.publishedAt, opts.withTime);
      return `<a href="${href}">${title}</a>  ${date}${opts.gap}<span data-views="${id}" data-views-w="${opts.viewsW}">${placeholder}</span>\n`;
    })
    .join("");
}

const desktopListing = render(DESKTOP);
const mobileListing = render(MOBILE);
---

<hr />
<pre class="my-3 hidden text-sm leading-7 md:block" set:html={desktopListing}></pre>
<pre class="my-3 overflow-x-auto text-sm leading-7 md:hidden" set:html={mobileListing}></pre>
<hr />

<script is:inline>
  fetch("/api/views.json")
    .then((r) => (r.ok ? r.json() : {}))
    .then((counts) => {
      document.querySelectorAll("[data-views]").forEach((el) => {
        const id = el.getAttribute("data-views");
        const w = Number(el.getAttribute("data-views-w")) || 0;
        const n = counts[id] ?? 0;
        el.textContent = String(n).padStart(w);
      });
    })
    .catch(() => {});
</script>
