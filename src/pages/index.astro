---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../lib/utils";

const allPosts = (await getCollection("posts"))
  .filter((post) => post.data.published)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const postCount = allPosts.length;
const recentPosts = allPosts.slice(0, 5);
---

<BaseLayout title="yeahjunheo">
  <!-- 1. Date with time comparison -->
  <div class="mb-6 text-center">
    <p class="font-serif text-2xl" id="date-line"></p>
    <p class="mt-2 font-serif text-sm italic text-zissou-bright-black" id="time-quip"></p>
  </div>

  <!-- Obi-Wan container -->
  <div id="obiwan-wrapper" class="obiwan-wrapper">
    <video autoplay loop muted playsinline>
      <source src="/obiwan-hello-there.mp4" type="video/mp4" />
      <source src="/obiwan-hello-there.webm" type="video/webm" />
    </video>
  </div>

  <!-- 2. Body text in large letters -->
  <section id="body-text" class="mb-10">
    <p class="font-serif text-3xl leading-relaxed">
      Why <span id="hello-there" class="cursor-pointer hover:text-zissou-red">hello there!</span> I'm <span class="font-bold text-zissou-blue">Yeahjun</span> and you've just stumbled on my <span class="wiggle inline-block text-zissou-magenta">think pad</span> on the <span class="bounce inline-block font-bold text-zissou-red">WEB</span>. I'm trying to do more <a href="/blog" class="inline-block text-zissou-green hover:text-zissou-blue" id="typing-writing" style="width:3.9em"></a>, <span class="text-zissou-yellow" id="dibble-dabble"></span>, and more with this site. If that's also your jam, keep a <span class="bookmark cursor-pointer text-zissou-magenta underline" id="bookmark-cta">bookmark</span> to give this page a try.
    </p>
  </section>

  <!-- 3. Post counter -->
  <section class="mb-10 text-center">
    <p class="font-serif text-7xl font-bold text-zissou-foreground">{postCount}</p>
    <p class="font-serif text-lg text-zissou-bright-black">posts so far!</p>
  </section>

  <!-- 4. Recent ramblings -->
  <section>
    <h2 class="mb-6 font-serif text-3xl font-bold text-center">Recent Ramblings</h2>
    {recentPosts.length === 0 && <p class="text-zissou-bright-black">No posts yet.</p>}
    <ul class="space-y-4">
      {recentPosts.map((post) => {
        const d = post.data.publishedAt;
        const month = d.toLocaleDateString("en-US", { month: "short" }).toUpperCase();
        const day = d.getDate();
        return (
          <li>
            <a href={`/blog/${post.id}`} class="group flex items-center gap-4">
              <span class="w-14 shrink-0 text-sm text-zissou-bright-black">{month}</span>
              <div class="flex flex-col justify-center">
                <h3 class="font-semibold group-hover:text-zissou-blue">{post.data.title}</h3>
                {post.data.excerpt && <p class="mt-0.5 text-sm text-zissou-bright-black">{post.data.excerpt}</p>}
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
</BaseLayout>

<script>
  function getHourOffset(localTz: string): number {
    const now = new Date();
    const localStr = now.toLocaleString("en-US", { timeZone: localTz, hour12: false, hour: "2-digit", minute: "2-digit" });
    const kyotoStr = now.toLocaleString("en-US", { timeZone: "Asia/Tokyo", hour12: false, hour: "2-digit", minute: "2-digit" });
    const [lh, lm] = localStr.split(":").map(Number);
    const [kh, km] = kyotoStr.split(":").map(Number);
    return (lh * 60 + lm - (kh * 60 + km)) / 60;
  }

  function pickQuip(diffHours: number): string {
    const abs = Math.abs(Math.round(diffHours));
    const unit = abs === 1 ? "hour" : "hours";

    if (abs === 0) {
      const sameZone = [
        "we're watching the same sunset right now",
        "same timezone, same vibes",
        "oh hey neighbor — same clock, same sky",
        "our clocks agree, that's a good start",
        "you're right on time",
        "look at us, perfectly in sync",
        "no time travel needed between us",
        "we share a timezone — it's basically fate",
        "zero hours apart, maximum solidarity",
        "the rare same-time visitor. welcome",
      ];
      return sameZone[Math.floor(Math.random() * sameZone.length)];
    }

    if (diffHours > 0) {
      // Reader is ahead of Kyoto
      const ahead = [
        `you're reading notes from someone ${abs} ${unit} in your past`,
        `you live ${abs} ${unit} in my future — any spoilers?`,
        `by the time I write this, you've already had ${abs} more ${unit} of coffee`,
        `you're ${abs} ${unit} ahead — save me a seat in tomorrow`,
        `from ${abs} ${unit} in your past, I hope the future is nice`,
        `you've had ${abs} extra ${unit} to figure life out. how's that going?`,
        `${abs} ${unit} ahead of me — you're basically a time traveler`,
        `I'm still catching up to your ${abs}-${unit} head start`,
        `you already know what happens ${abs} ${unit} from now`,
        `writing this ${abs} ${unit} behind you. no rush though`,
      ];
      return ahead[Math.floor(Math.random() * ahead.length)];
    }

    // Reader is behind Kyoto
    const behind = [
      `I'm writing this ${abs} ${unit} from your future`,
      `you're ${abs} ${unit} behind — take your time, I'll wait`,
      `greetings from ${abs} ${unit} in your future. it's fine here`,
      `I've already lived the ${abs} ${unit} you're about to`,
      `${abs} ${unit} ahead of you — the tea is still warm`,
      `sending this back ${abs} ${unit} through the internet tubes`,
      `you'll get here in ${abs} ${unit}. no spoilers`,
      `I'm ${abs} ${unit} ahead but somehow still procrastinating`,
      `from ${abs} ${unit} in your future: it's worth the wait`,
      `living ${abs} ${unit} ahead, still no flying cars though`,
    ];
    return behind[Math.floor(Math.random() * behind.length)];
  }

  function updateDateLine() {
    const now = new Date();
    const localTz = Intl.DateTimeFormat().resolvedOptions().timeZone;

    const localDate = new Intl.DateTimeFormat("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
      timeZone: localTz,
    }).format(now);

    const dateEl = document.getElementById("date-line");
    const quipEl = document.getElementById("time-quip");

    if (dateEl) dateEl.textContent = localDate;
    if (quipEl) {
      const diff = getHourOffset(localTz);
      quipEl.textContent = `[ ${pickQuip(diff)} ]`;
    }
  }

  updateDateLine();

  // Obi-Wan hello there
  const helloAudio = new Audio("/audio/obi-wan-hello-there.mp3");
  const helloTrigger = document.getElementById("hello-there");
  const wrapper = document.getElementById("obiwan-wrapper")!;
  const bodySection = document.getElementById("body-text")!;
  let playing = false;

  helloTrigger?.addEventListener("mouseenter", () => {
    if (playing) return;
    wrapper.classList.add("peek");
  });

  helloTrigger?.addEventListener("mouseleave", () => {
    if (playing) return;
    wrapper.classList.remove("peek");
  });

  helloTrigger?.addEventListener("click", () => {
    if (playing) return;
    playing = true;
    wrapper.classList.remove("peek");
    wrapper.classList.add("reveal");
    helloAudio.currentTime = 0;
    helloAudio.play();
    setTimeout(() => {
      wrapper.classList.remove("reveal");
      setTimeout(() => { playing = false; }, 500);
    }, 2000);
  });

  // Dibble-dabbling wave
  const dibble = document.getElementById("dibble-dabble");
  if (dibble) {
    const text = "dibble-dabbling";
    dibble.innerHTML = text.split("").map((ch, i) =>
      ch === " "
        ? " "
        : `<span class="wave-letter" style="animation-delay:${i * 0.08}s">${ch}</span>`
    ).join("");
  }

  // Typing effect on "writing"
  const typingEl = document.getElementById("typing-writing");
  if (typingEl) {
    const word = "writing";
    let i = 0;
    let deleting = false;
    typingEl.textContent = "";

    function tick() {
      if (!deleting) {
        typingEl!.textContent = word.slice(0, i + 1);
        i++;
        if (i >= word.length) {
          deleting = true;
          setTimeout(tick, 1500);
        } else {
          setTimeout(tick, 150);
        }
      } else {
        i--;
        typingEl!.textContent = word.slice(0, i);
        if (i <= 0) {
          deleting = false;
          setTimeout(tick, 500);
        } else {
          setTimeout(tick, 80);
        }
      }
    }
    tick();
  }

  // Bookmark CTA
  document.getElementById("bookmark-cta")?.addEventListener("click", () => {
    alert("Press Ctrl+D (or Cmd+D on Mac) to bookmark this page!");
  });
</script>

<style is:global>
  .wiggle {
    animation: wiggle 3s ease-in-out infinite;
  }

  .bounce {
    animation: bounce 2s ease-in-out infinite;
  }

  .wave-letter {
    display: inline-block;
    animation: wave 1.5s ease-in-out infinite;
  }

  @keyframes wiggle {
    0%, 100% { transform: rotate(0deg); }
    25% { transform: rotate(2deg); }
    75% { transform: rotate(-2deg); }
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  @keyframes wave {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }

  #typing-writing::after {
    content: "|";
    animation: blink 0.7s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .obiwan-wrapper {
    overflow: hidden;
    height: 0;
    margin-top: 0;
    display: flex;
    justify-content: center;
    transition: height 0.5s ease-out, margin-top 0.5s ease-out;
  }

  .obiwan-wrapper video {
    height: 250px;
    width: auto;
    object-fit: contain;
  }

  .obiwan-wrapper.peek {
    height: 60px;
    margin-top: -60px;
  }

  .obiwan-wrapper.reveal {
    height: 250px;
    margin-top: 0;
    transition: height 0.6s ease-out, margin-top 0.6s ease-out;
  }

</style>
