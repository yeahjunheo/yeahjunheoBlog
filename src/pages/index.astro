---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../lib/utils";

const posts = (await getCollection("posts"))
  .filter((post) => post.data.published)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 5);
---

<BaseLayout title="yeahjunheo">
  <h1 class="mb-8 text-3xl font-bold">Latest Posts</h1>
  {posts.length === 0 && <p class="text-gray-500">No posts yet.</p>}
  <ul class="space-y-6">
    {posts.map((post) => (
      <li>
        <a href={`/posts/${post.id}`} class="group block">
          <h2 class="text-xl font-semibold group-hover:underline">{post.data.title}</h2>
          <time class="text-sm text-gray-500">{formatDate(post.data.publishedAt)}</time>
          {post.data.excerpt && <p class="mt-1 text-gray-600">{post.data.excerpt}</p>}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
