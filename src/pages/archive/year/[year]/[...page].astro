---
import "../../../../styles/global.css";
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Archive from "../../../../components/Archive.astro";

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const all = (await getCollection("posts"))
    .filter((p) => p.data.published)
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

  const years = [...new Set(all.map((p) => p.data.publishedAt.getFullYear()))];
  return years.flatMap((year) => {
    const yearPosts = all.filter((p) => p.data.publishedAt.getFullYear() === year);
    return paginate(yearPosts, { pageSize: 20, params: { year: String(year) } });
  });
};

const { page } = Astro.props;
const year = Number(Astro.params.year);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" sizes="16x16" href="/icons8-terminal-matisse-16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/icons8-terminal-matisse-32.png" />
    <link rel="icon" type="image/png" sizes="96x96" href="/icons8-terminal-matisse-96.png" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>archive {year} · yeahjunheo</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=JetBrains+Mono:wght@400;700&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,600;0,6..72,700;1,6..72,400&display=swap"
    />
  </head>
  <body>
    <main class="mx-auto max-w-3xl p-8">
      <p class="text-sm"><a href="/">../</a></p>
      <div class="mt-6">
        <Archive page={page} activeYear={year} />
      </div>
    </main>
  </body>
</html>
