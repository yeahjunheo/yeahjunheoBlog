---
import type { GetStaticPaths } from "astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/utils";

export const getStaticPaths = (async ({ paginate }) => {
  const posts = (await getCollection("posts"))
    .filter((post) => post.data.published)
    .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

  return paginate(posts, { pageSize: 10 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;

const allPosts = (await getCollection("posts"))
  .filter((post) => post.data.published)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const MONTH_NAMES = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];

const dateGroups: Record<number, Set<number>> = {};
for (const post of allPosts) {
  const d = post.data.publishedAt;
  const year = d.getFullYear();
  const month = d.getMonth();
  if (!dateGroups[year]) dateGroups[year] = new Set();
  dateGroups[year].add(month);
}
const sortedYears = Object.keys(dateGroups).map(Number).sort((a, b) => b - a);

const allPostsJson = JSON.stringify(
  allPosts.map((post) => ({
    id: post.id,
    title: post.data.title,
    excerpt: post.data.excerpt || null,
    publishedAt: post.data.publishedAt.toISOString(),
  }))
);
---

<BaseLayout title={`Blog${page.currentPage > 1 ? ` - Page ${page.currentPage}` : ""} - yeahjunheo`}>
  <div class="mb-8 flex items-center gap-3">
    <h1 class="text-3xl font-bold">All Posts</h1>
    <div class="relative" id="date-filter">
      <button
        id="date-filter-btn"
        class="catalogue-handle group flex items-center gap-2"
      >
        <span class="catalogue-label" id="date-filter-label">All</span>
        <svg class="h-3 w-3 text-zissou-cream transition-transform" id="date-filter-arrow" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
        </svg>
      </button>

      <div
        id="date-filter-menu"
        class="catalogue-drawer absolute left-0 top-full z-10 mt-2 hidden"
      >
        <div class="catalogue-drawer-inner">
          <button
            class="date-option catalogue-card catalogue-card--all"
            data-year=""
            data-month=""
          >
            <span class="catalogue-card-text">All Dates</span>
          </button>

          <div class="catalogue-divider"></div>

          {sortedYears.map((year) => {
            const months = [...dateGroups[year]].sort((a, b) => b - a);
            return (
              <div class="catalogue-year-group">
                <button
                  class="date-option catalogue-tab"
                  data-year={year}
                  data-month=""
                >
                  <span class="catalogue-tab-text">{year}</span>
                </button>
                <div class="catalogue-month-tray">
                  {months.map((m) => (
                    <button
                      class="date-option catalogue-card"
                      data-year={year}
                      data-month={m}
                    >
                      <span class="catalogue-card-text">{MONTH_NAMES[m]}</span>
                    </button>
                  ))}
                </div>
              </div>
            );
          })}
        </div>
      </div>
    </div>
  </div>

  <div id="no-posts-msg" class="hidden text-zissou-bright-black">No posts for this period.</div>
  {page.data.length === 0 && <p id="no-posts-default" class="text-zissou-bright-black">No posts yet.</p>}

  <ul id="post-list-default" class="space-y-4">
    {page.data.map((post) => {
      const d = post.data.publishedAt;
      const month = d.toLocaleDateString("en-US", { month: "short" }).toUpperCase();
      const day = d.getDate();
      return (
        <li>
          <a href={`/blog/${post.id}`} class="group flex items-center gap-4">
            <span class="w-14 shrink-0 text-sm text-zissou-bright-black">{month} {day}</span>
            <div class="flex flex-col justify-center">
              <h3 class="font-semibold group-hover:text-zissou-red">{post.data.title}</h3>
              {post.data.excerpt && <p class="mt-0.5 text-sm text-zissou-bright-black">{post.data.excerpt}</p>}
            </div>
          </a>
        </li>
      );
    })}
  </ul>

  <ul id="post-list-filtered" class="hidden space-y-4"></ul>

  <nav id="filtered-pagination-nav" class="mt-10 grid grid-cols-3 items-center">
    <div class="text-left">
      <span id="filtered-prev" class="text-sm hover:text-zissou-red cursor-pointer"></span>
    </div>
    <span id="filtered-page-info" class="text-center text-sm text-zissou-bright-black"></span>
    <div class="text-right">
      <span id="filtered-next" class="text-sm hover:text-zissou-red cursor-pointer"></span>
    </div>
  </nav>

  <nav id="pagination-nav" class="mt-10 grid grid-cols-3 items-center">
    <div class="text-left">
      {page.url.prev && (
        <a href={page.url.prev} class="text-sm hover:text-zissou-red">&larr; Newer</a>
      )}
    </div>
    <span class="text-center text-sm text-zissou-bright-black">Page {page.currentPage} of {page.lastPage}</span>
    <div class="text-right">
      {page.url.next && (
        <a href={page.url.next} class="text-sm hover:text-zissou-red">Older &rarr;</a>
      )}
    </div>
  </nav>
</BaseLayout>

<script define:vars={{ allPostsJson }}>
  const allPosts = JSON.parse(allPostsJson);
  const btn = document.getElementById("date-filter-btn");
  const menu = document.getElementById("date-filter-menu");
  const arrow = document.getElementById("date-filter-arrow");
  const label = document.getElementById("date-filter-label");
  const defaultList = document.getElementById("post-list-default");
  const filteredList = document.getElementById("post-list-filtered");
  const paginationNav = document.getElementById("pagination-nav");
  const filteredPaginationNav = document.getElementById("filtered-pagination-nav");
  const filteredPrev = document.getElementById("filtered-prev");
  const filteredNext = document.getElementById("filtered-next");
  const filteredPageInfo = document.getElementById("filtered-page-info");
  const noPostsMsg = document.getElementById("no-posts-msg");
  const noPostsDefault = document.getElementById("no-posts-default");
  const MONTH_NAMES = ["Jan", "Feb", "Mar", "Apr", "May", "Jun", "Jul", "Aug", "Sep", "Oct", "Nov", "Dec"];
  const PAGE_SIZE = 10;

  let open = false;
  let filteredResults = [];
  let filteredPage = 1;

  function toggle() {
    open = !open;
    menu.classList.toggle("hidden", !open);
    arrow.style.transform = open ? "rotate(180deg)" : "";
  }

  btn.addEventListener("click", (e) => {
    e.stopPropagation();
    toggle();
  });

  document.addEventListener("click", (e) => {
    if (open && !menu.contains(e.target)) {
      toggle();
    }
  });

  function renderPostHtml(p) {
    const d = new Date(p.publishedAt);
    const mon = d.toLocaleDateString("en-US", { month: "short" }).toUpperCase();
    const day = d.getDate();
    const excerptHtml = p.excerpt
      ? `<p class="mt-0.5 text-sm text-zissou-bright-black">${p.excerpt}</p>`
      : "";
    return `<li>
      <a href="/blog/${p.id}" class="group flex items-center gap-4">
        <span class="w-14 shrink-0 text-sm text-zissou-bright-black">${mon} ${day}</span>
        <div class="flex flex-col justify-center">
          <h3 class="font-semibold group-hover:text-zissou-red">${p.title}</h3>
          ${excerptHtml}
        </div>
      </a>
    </li>`;
  }

  function renderFilteredPage() {
    const totalPages = Math.ceil(filteredResults.length / PAGE_SIZE);
    const start = (filteredPage - 1) * PAGE_SIZE;
    const pageItems = filteredResults.slice(start, start + PAGE_SIZE);

    filteredList.innerHTML = pageItems.map(renderPostHtml).join("");

    filteredPageInfo.textContent = `Page ${filteredPage} of ${totalPages}`;
    filteredPrev.textContent = filteredPage > 1 ? "\u2190 Newer" : "";
    filteredPrev.style.pointerEvents = filteredPage > 1 ? "" : "none";
    filteredNext.textContent = filteredPage < totalPages ? "Older \u2192" : "";
    filteredNext.style.pointerEvents = filteredPage < totalPages ? "" : "none";
    filteredPaginationNav.classList.remove("hidden");
  }

  filteredPrev.addEventListener("click", () => {
    if (filteredPage > 1) {
      filteredPage--;
      renderFilteredPage();
    }
  });

  filteredNext.addEventListener("click", () => {
    const totalPages = Math.ceil(filteredResults.length / PAGE_SIZE);
    if (filteredPage < totalPages) {
      filteredPage++;
      renderFilteredPage();
    }
  });

  function clearActiveStates() {
    menu.querySelectorAll(".date-option").forEach((el) => el.classList.remove("active"));
  }

  // Set "All" as initially active
  menu.querySelector(".catalogue-card--all")?.classList.add("active");

  menu.querySelectorAll(".date-option").forEach((opt) => {
    opt.addEventListener("click", () => {
      const year = opt.dataset.year;
      const month = opt.dataset.month;

      clearActiveStates();
      opt.classList.add("active");

      // Also highlight the parent year tab when a month is selected
      if (year && month !== "") {
        const yearTab = menu.querySelector(`.catalogue-tab[data-year="${year}"]`);
        if (yearTab) yearTab.classList.add("active");
      }

      if (!year) {
        label.textContent = "All";
        defaultList.classList.remove("hidden");
        filteredList.classList.add("hidden");
        paginationNav.classList.remove("hidden");
        filteredPaginationNav.classList.add("hidden");
        noPostsMsg.classList.add("hidden");
        if (noPostsDefault) noPostsDefault.classList.remove("hidden");
      } else {
        const y = parseInt(year);
        const yearOnly = month === "";
        label.textContent = yearOnly ? `${y}` : `${MONTH_NAMES[parseInt(month)]} ${y}`;

        filteredResults = allPosts.filter((p) => {
          const d = new Date(p.publishedAt);
          return d.getFullYear() === y && (yearOnly || d.getMonth() === parseInt(month));
        });
        filteredPage = 1;

        defaultList.classList.add("hidden");
        paginationNav.classList.add("hidden");
        if (noPostsDefault) noPostsDefault.classList.add("hidden");

        if (filteredResults.length === 0) {
          filteredList.classList.add("hidden");
          filteredPaginationNav.classList.add("hidden");
          noPostsMsg.classList.remove("hidden");
        } else {
          noPostsMsg.classList.add("hidden");
          filteredList.classList.remove("hidden");
          renderFilteredPage();
        }
      }

      toggle();
    });
  });
</script>
