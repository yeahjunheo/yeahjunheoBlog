---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDate } from "../../lib/utils";

const posts = (await getCollection("posts"))
  .filter((post) => post.data.published)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---

<BaseLayout title="Blog - yeahjunheo">
  <h1 class="mb-8 text-3xl font-bold">All Posts</h1>
  {posts.length === 0 && <p class="text-gray-500">No posts yet.</p>}
  <ul class="space-y-6">
    {posts.map((post) => (
      <li>
        <a href={`/blog/${post.id}`} class="group block">
          <h2 class="text-xl font-semibold group-hover:underline">{post.data.title}</h2>
          <div class="flex items-center gap-3 text-sm text-gray-500">
            <time>{formatDate(post.data.publishedAt)}</time>
            {post.data.tags.length > 0 && (
              <span>{post.data.tags.join(", ")}</span>
            )}
          </div>
          {post.data.excerpt && <p class="mt-1 text-gray-600">{post.data.excerpt}</p>}
        </a>
      </li>
    ))}
  </ul>
</BaseLayout>
