---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { slugify } from "../../lib/utils";

const posts = (await getCollection("posts")).filter((post) => post.data.published);

const tagCounts = new Map<string, number>();
for (const post of posts) {
  for (const tag of post.data.tags) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<BaseLayout title="Tags - yeahjunheo">
  <h1 class="mb-8 text-3xl font-bold">Tags</h1>
  {tags.length === 0 && <p class="text-gray-500">No tags yet.</p>}
  <div class="flex flex-wrap gap-3">
    {tags.map(([tag, count]) => (
      <a
        href={`/tags/${slugify(tag)}`}
        class="rounded border border-gray-200 px-3 py-1.5 text-sm hover:bg-gray-50"
      >
        {tag} <span class="text-gray-400">({count})</span>
      </a>
    ))}
  </div>
</BaseLayout>
